{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "attach",
      "name": "Debug already-running process",
      "pid": "${command:pickMyProcess}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug executable 'zerp'",
      "cargo": {
        "args": ["build", "--bin=zerp"],
        "filter": {
          "name": "zerp",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug MacOS executable",
      "preLaunchTask": "build_zerplocal",
      "program": "${workspaceFolder}/target/debug/bundle/osx/ZerpLocal.app/Contents/MacOS/zerp",
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug executable 'zerp' with fast_dev",
      "cargo": {
        "args": ["build", "--bin=zerp", "--features=fast_dev"],
        "filter": {
          "name": "zerp",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug executable 'zerp' with with_local_server",
      "cargo": {
        "args": ["build", "--bin=zerp", "--features=with_local_server"],
        "filter": {
          "name": "zerp",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug MacOS executable local session sharing server",
      "preLaunchTask": "build_zerplocal_localsessionsharing",
      "program": "${workspaceFolder}/target/debug/bundle/osx/ZerpLocal.app/Contents/MacOS/zerp",
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug MacOS executable with fast_dev",
      "env": {
        "RUST_BACKTRACE": "1"
      },
      "preLaunchTask": "build_zerplocal_fastdev",
      "program": "${workspaceFolder}/target/debug/bundle/osx/ZerpLocal.app/Contents/MacOS/zerp",
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug MacOS executable with fast_dev + local session sharing server",
      "preLaunchTask": "build_zerplocal_fastdev_localsessionsharing",
      "program": "${workspaceFolder}/target/debug/bundle/osx/ZerpLocal.app/Contents/MacOS/zerp",
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug unit tests in executable 'zerp'",
      "cargo": {
        "args": ["test", "--no-run", "--bin=zerp", "--package=warp"],
        "filter": {
          "name": "zerp",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug integration tests in executable 'integration'",
      "cargo": {
        "args": ["build", "--bin=integration", "--package=warp"],
        "env": {
          "WARPUI_USE_REAL_DISPLAY_IN_INTEGRATION_TESTS": "1"
        },
        "filter": {
          "name": "integration",
          "kind": "bin"
        }
      },
      "args": ["test_waterfall_input"],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug unit tests in library 'warpui'",
      "cargo": {
        "args": ["test", "--no-run", "--lib", "--package=warpui"],
        "filter": {
          "name": "warpui",
          "kind": "lib"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "sourceLanguages": ["rust"]
    }
  ]
}
