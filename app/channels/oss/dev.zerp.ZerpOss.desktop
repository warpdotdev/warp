[Desktop Entry]
# The version of the desktop entry spec this conforms to.
Version=1.0

Type=Application

Name=ZerpOss
GenericName=TerminalEmulator

Exec=zerp-terminal-oss %U
StartupWMClass=dev.zerp.ZerpOss

Keywords=shell;prompt;command;commandline;cmd;

Icon=dev.zerp.ZerpOss

Categories=System;TerminalEmulator;

# Don't run this application within a terminal.
Terminal=false

# Register ourselves as the handler for zerposs:// URLs.
MimeType=x-scheme-handler/zerposs;
