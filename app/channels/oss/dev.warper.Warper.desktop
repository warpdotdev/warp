[Desktop Entry]
# The version of the desktop entry spec this conforms to.
Version=1.0

Type=Application

Name=Warper
GenericName=TerminalEmulator

Exec=warp-terminal %U
StartupWMClass=dev.warper.Warper

Keywords=shell;prompt;command;commandline;cmd;

Icon=dev.warper.Warper

Categories=System;TerminalEmulator;

# Don't run this application within a terminal.
Terminal=false

# Register ourselves as the handler for warper:// URLs.
MimeType=x-scheme-handler/warper;
