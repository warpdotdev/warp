[Desktop Entry]
# The version of the desktop entry spec this conforms to.
Version=1.0

Type=Application

Name=ZerpPreview
GenericName=TerminalEmulator

Exec=zerp-terminal-preview %U
StartupWMClass=dev.zerp.ZerpPreview

Keywords=shell;prompt;command;commandline;cmd;

Icon=dev.zerp.ZerpPreview

Categories=System;TerminalEmulator;

# Don't run this application within a terminal.
Terminal=false

# Register ourselves as the handler for zerppreview:// URLs.
MimeType=x-scheme-handler/zerppreview;
