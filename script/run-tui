#!/bin/bash
#
# Build and run the experimental Warp agent TUI (the `tui` bin) attached to the
# current terminal.
#
# The TUI is a plain CLI binary that must stay attached to the terminal
# (stdin/stdout), so it can't go through `./script/run`, which bundles and
# launches a GUI `.app`.
#
# Keychain note: the full app reads credentials from the macOS keychain at
# startup. A `cargo`-built binary is not in those keychain items' ACLs, so macOS
# would otherwise prompt ("Warp wants to use your confidential information") on
# every run. To avoid that, this script defaults to `fast_dev` (a test user, no
# real login, no keychain access). Pass `--login` to use your real account for
# real agent responses (see the one-time setup note printed in that mode).
#
# Usage:
#   ./script/run-tui [--login] [--release] [--features extra,features] [-- <args for tui>]

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"
cd "${REPO_ROOT}"

USE_LOGIN=false
FEATURES="tui"
PROFILE_DIR="debug"
CARGO_PARAMS=()
TUI_ARGS=()

while (("$#")); do
  case "$1" in
  --)
    shift
    TUI_ARGS=("$@")
    break
    ;;
  --login)
    USE_LOGIN=true
    shift
    ;;
  --features)
    if [ -n "$2" ] && [ "${2:0:1}" != "-" ]; then
      FEATURES="${FEATURES},$2"
      shift 2
    else
      echo "Error: argument for --features is missing" >&2
      exit 1
    fi
    ;;
  --release)
    CARGO_PARAMS+=("$1")
    PROFILE_DIR="release"
    shift
    ;;
  *)
    echo "Error: unknown argument '$1' (pass arguments for the tui binary after --)" >&2
    exit 1
    ;;
  esac
done

if [ "${USE_LOGIN}" = false ]; then
  # `fast_dev` enables `skip_login` (a test user), so the app never reads the
  # real keychain items and macOS never prompts.
  FEATURES="${FEATURES},fast_dev"
  echo "Running with fast_dev (test user, no keychain prompts)."
  echo "For real agent responses, run: ./script/run-tui --login"
else
  cat >&2 <<'EOF'
Running with real login. On first run macOS may prompt to access the
"dev.warp.Warp-Dev" keychain item(s). To stop it prompting on every run WITHOUT
codesigning: open Keychain Access, find each "dev.warp.Warp-Dev" item, and set
Access Control -> "Allow all applications to access this item". That grant is
independent of the binary's identity, so it persists across rebuilds.
EOF
fi

echo "Building tui (features: ${FEATURES})..."
cargo build --bin tui --features "${FEATURES}" "${CARGO_PARAMS[@]}"

BIN="target/${PROFILE_DIR}/tui"
echo "Launching ${BIN}..."
exec "${BIN}" "${TUI_ARGS[@]}"
