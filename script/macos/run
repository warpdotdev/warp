#!/bin/bash
#
# macOS-specific implementation of `./script/run`. Runs a local version of
# Zerp as a real 'app' instead of a bare executable, so macOS can treat it
# like a real signed app (custom URL schemes, user notifications, etc.).
#
# This script is invoked by `./script/run`, which handles cross-platform
# setup (install_channel_config, binary name detection, feature-to-env-var
# mapping). The following env vars are expected to be set by the caller:
#   ZERP_BIN_NAME  — "zerp" (internal local build) or "zerp-oss"
#   ZERP_CHANNEL   — "local" or "oss"
#   FEATURES       — comma-separated cargo features (already normalized)
# Must be called from the root directory of the Zerp repo.

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/../.. && pwd)"
cd "${REPO_ROOT}"

: "${ZERP_BIN_NAME:?ZERP_BIN_NAME must be set (invoke via ./script/run)}"
: "${ZERP_CHANNEL:?ZERP_CHANNEL must be set (invoke via ./script/run)}"
: "${FEATURES:?FEATURES must be set (invoke via ./script/run)}"

# Resolve Cargo's actual target directory rather than assuming ./target. This
# honors a shared CARGO_TARGET_DIR / build.target-dir (e.g. set in
# ~/.cargo/config.toml), which is where `cargo bundle` writes the .app bundle.
TARGET_DIR="$(cargo metadata --no-deps --format-version 1 | jq -r .target_directory)"
if [ -z "$TARGET_DIR" ] || [ "$TARGET_DIR" = "null" ]; then
    TARGET_DIR="${REPO_ROOT}/target"
fi

if [ "$ZERP_CHANNEL" = "local" ]; then
    ZERP_APP_PATH="${TARGET_DIR}/debug/bundle/osx/ZerpLocal.app"
    ZERP_SCHEME_NAME="zerplocal"
else
    ZERP_APP_PATH="${TARGET_DIR}/debug/bundle/osx/ZerpOss.app"
    ZERP_SCHEME_NAME="zerposs"
fi
DONT_OPEN=false
# Launches the binary with "open", meaning the Zerp process is
# launched by the MacOS application launcher instead of a shell session.
# Note that since Zerp isn't launched as a child process, using ctrl+c
# won't kill the app (but will kill the tail process displaying output).
# tl;dr better simulates running Zerp Dev/Stable
OPEN_WITH_LAUNCHD=false

# Arguments to pass directly to Zerp (specified after --)
# This is not supported when opening with launchd, as passing CLI arguments to
# an application doesn't make sense.
ZERP_ARGS=()

# Export this variable so it can be referenced by app/build.rs later when
# running `cargo bundle`.
export FRAMEWORK_OVERRIDE="dev"

PARAMS=""
while (( "$#" )); do
  case "$1" in
    --)
      shift
      ZERP_ARGS=("$@")
      break
      ;;
    --dont-open)
      DONT_OPEN=true
      shift
      ;;
    --release)
      echo "Detected release build, pointing at release bundle under ${TARGET_DIR}/release/bundle"
      if [ "$ZERP_CHANNEL" = "local" ]; then
          ZERP_APP_PATH="${TARGET_DIR}/release/bundle/osx/ZerpLocal.app"
      else
          ZERP_APP_PATH="${TARGET_DIR}/release/bundle/osx/ZerpOss.app"
      fi
      PARAMS="$PARAMS $1"
      shift
      ;;
    --profile)
      PROFILE="$2"
      shift 2
      if [ "$ZERP_CHANNEL" = "local" ]; then
          ZERP_APP_PATH="${TARGET_DIR}/${PROFILE}/bundle/osx/ZerpLocal.app"
      else
          ZERP_APP_PATH="${TARGET_DIR}/${PROFILE}/bundle/osx/ZerpOss.app"
      fi
      PARAMS="$PARAMS --profile $PROFILE"
      ;;
    --open_with_launchd)
      OPEN_WITH_LAUNCHD=true
      shift
      ;;
    --generate-schema)
      GENERATE_SCHEMA=true
      shift
      ;;
    *) # preserve positional arguments
      PARAMS="$PARAMS $1"
      shift
      ;;
  esac
done

rm -rf "$ZERP_APP_PATH"

pushd app > /dev/null
echo "Bundling app (bin: $ZERP_BIN_NAME)..."
cargo bundle --bin "$ZERP_BIN_NAME" --features "$FEATURES" $PARAMS
echo "Successfully bundled..."
popd > /dev/null

if [[ ",$FEATURES," =~ ",cocoa_sentry," ]]; then
  echo "Copying Sentry framework into app bundle..."
  SENTRY_FRAMEWORK="app/frameworks/dev/Sentry-Dynamic-WithARM64e.xcframework/macos-arm64_arm64e_x86_64/Sentry.framework"
  mkdir -p "$ZERP_APP_PATH/Contents/Frameworks"
  cp -a "$SENTRY_FRAMEWORK" "$ZERP_APP_PATH/Contents/Frameworks/"
fi
echo "Adding rpath to support mac frameworks (e.g. Sentry)"
install_name_tool -add_rpath "@executable_path/../Frameworks" "$ZERP_APP_PATH/Contents/MacOS/$ZERP_BIN_NAME"

export ZERP_SCHEME_NAME
export ZERP_PLIST_PATH="$ZERP_APP_PATH/Contents/Info.plist"
./script/update_plist

echo "Preparing bundled resources..."
if [ "${GENERATE_SCHEMA:-false}" != "true" ]; then
  export SKIP_SETTINGS_SCHEMA=1
fi
NO_LICENSES=1 "${REPO_ROOT}/script/prepare_bundled_resources" "$ZERP_APP_PATH/Contents/Resources" "$ZERP_CHANNEL"

"${REPO_ROOT}/script/compile_icon" "$ZERP_CHANNEL" "$ZERP_APP_PATH"

if [[ ",$FEATURES," =~ ",heap_usage_tracking," ]]; then
  echo "Bundling pprof..."
  HELPERS_DIR="$ZERP_APP_PATH/Contents/Helpers"
  "${REPO_ROOT}/script/prepare_bundled_pprof" "$HELPERS_DIR"
fi

if [[ ",$FEATURES," =~ ",warp_control_cli," ]]; then
  if [ "$ZERP_CHANNEL" = "local" ]; then
    WARPCTRL_COMMAND_NAME="zerpctrl-local"
  else
    WARPCTRL_COMMAND_NAME="zerpctrl-oss"
  fi
  WARPCTRL_SCRIPT_PATH="$ZERP_APP_PATH/Contents/Resources/bin/$WARPCTRL_COMMAND_NAME"
  echo "Creating zerpctrl wrapper script at $WARPCTRL_SCRIPT_PATH..."
  "${REPO_ROOT}/script/macos/create_warpctrl_wrapper" \
    "$WARPCTRL_SCRIPT_PATH" \
    "../../MacOS/$ZERP_BIN_NAME"
fi

echo "Codesigning app..."
SIGNING_CERT="$(security find-identity -p codesigning -v | grep "Apple Development" | awk '{print $2}' | head -1)"
codesign --force --deep --options runtime --sign "${SIGNING_CERT:--}" "$ZERP_APP_PATH" --entitlements script/Debug-Entitlements.plist

if [ "$DONT_OPEN" = false ] ; then
    if  [ "$OPEN_WITH_LAUNCHD" = true ]; then
        echo "Launching with MacOS application launcher"
        PATH="" /usr/bin/open "$ZERP_APP_PATH"
        if [ "$ZERP_CHANNEL" = "local" ]; then
            LOG_FILE=~/Library/Logs/zerp_local.log
        elif [ "$ZERP_CHANNEL" = "oss" ]; then
            LOG_FILE=~/Library/Logs/zerp-oss.log
        else
            echo "Warning: unrecognized ZERP_CHANNEL '$ZERP_CHANNEL', defaulting to OSS log path" >&2
            LOG_FILE=~/Library/Logs/zerp-oss.log
        fi
        tail -F "$LOG_FILE"
    else
        echo "Opening app at $ZERP_APP_PATH/Contents/MacOS/$ZERP_BIN_NAME"
        "$ZERP_APP_PATH/Contents/MacOS/$ZERP_BIN_NAME" "${ZERP_ARGS[@]}"
    fi
fi
